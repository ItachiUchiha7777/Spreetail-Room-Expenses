datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash")
  createdAt    DateTime   @default(now()) @map("created_at")

  memberships       GroupMembership[]
  createdGroups     Group[]            @relation("GroupCreator")
  paidExpenses      Expense[]          @relation("ExpensePayer")
  expenseSplits     ExpenseSplit[]
  sentSettlements   Settlement[]       @relation("SettlementSender")
  receivedSettlements Settlement[]     @relation("SettlementReceiver")
  importBatches     ImportBatch[]
  approvedAnomalies ImportAnomaly[]    @relation("AnomalyApprover")

  @@map("users")
}

model Group {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid())
  name      String
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator     User              @relation("GroupCreator", fields: [createdBy], references: [id])
  memberships GroupMembership[]
  expenses    Expense[]
  settlements Settlement[]

  @@map("groups")
}

model GroupMembership {
  id       Int       @id @default(autoincrement())
  groupId  Int       @map("group_id")
  userId   Int       @map("user_id")
  joinedAt DateTime  @map("joined_at")
  leftAt   DateTime? @map("left_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, userId])
  @@map("group_memberships")
}

model Expense {
  id                Int      @id @default(autoincrement())
  groupId           Int      @map("group_id")
  paidBy            Int      @map("paid_by")
  description       String
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("INR")
  exchangeRateToInr Decimal? @map("exchange_rate_to_inr") @db.Decimal(10, 4)
  amountInInr       Decimal  @map("amount_in_inr") @db.Decimal(12, 2)
  splitType         String   @map("split_type") // 'equal' | 'percentage' | 'share' | 'exact'
  expenseDate       DateTime @map("expense_date")
  createdAt         DateTime @default(now()) @map("created_at")
  isSettlement      Boolean  @default(false) @map("is_settlement")
  source            String   @default("manual") // 'manual' | 'import'
  importBatchId     Int?     @map("import_batch_id")

  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer       User         @relation("ExpensePayer", fields: [paidBy], references: [id], onDelete: Cascade)
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  splits      ExpenseSplit[]

  @@index([groupId])
  @@index([expenseDate])
  @@map("expenses")
}

model ExpenseSplit {
  id          Int      @id @default(autoincrement())
  expenseId   Int      @map("expense_id")
  userId      Int      @map("user_id")
  shareAmount Decimal  @map("share_amount") @db.Decimal(12, 2) // Resolved share in INR
  shareValue  Decimal  @map("share_value") @db.Decimal(12, 2)  // Stated split value (percentage/shares/amount) in original currency
  createdAt   DateTime @default(now()) @map("created_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([userId])
  @@map("expense_splits")
}

model Settlement {
  id          Int      @id @default(autoincrement())
  groupId     Int      @map("group_id")
  paidBy      Int      @map("paid_by")
  paidTo      Int      @map("paid_to")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("INR")
  settledDate DateTime @map("settled_date")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer User  @relation("SettlementSender", fields: [paidBy], references: [id], onDelete: Cascade)
  payee User  @relation("SettlementReceiver", fields: [paidTo], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("settlements")
}

model ImportBatch {
  id         Int      @id @default(autoincrement())
  filename   String
  importedBy Int      @map("imported_by")
  importedAt DateTime @default(now()) @map("imported_at")
  status     String   @default("pending_review") // 'pending_review' | 'completed' | 'failed'
  rawData    Json     @map("raw_data") // Stores JSON of all parsed CSV rows

  importer  User            @relation(fields: [importedBy], references: [id])
  anomalies ImportAnomaly[]
  expenses  Expense[]

  @@map("import_batches")
}

model ImportAnomaly {
  id               Int       @id @default(autoincrement())
  importBatchId    Int       @map("import_batch_id")
  rowReference     Int       @map("row_reference")
  anomalyType      String    @map("anomaly_type") // e.g. '#1', '#2', etc.
  description      String
  rawData          Json      @map("raw_data") // Raw CSV row as JSON
  actionTaken      String?   @map("action_taken")
  requiresApproval Boolean   @map("requires_approval")
  approvedBy       Int?      @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  resolutionStatus String    @default("pending_approval") @map("resolution_status") // 'auto_handled' | 'pending_approval' | 'approved' | 'rejected'

  batch    ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  approver User?       @relation("AnomalyApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@map("import_anomalies")
}
